{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "src": ["./src/*"],
      "@ui/components/*": ["./src/components/*"],
      "@ui/hooks/*": ["./src/hooks/*"],
      "@/types/*": ["./src/types/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
