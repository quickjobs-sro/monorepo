{
    "name": "job-portal",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev --port 3000",
        "build": "next build",
        "start": "next start",
        "lint": "eslint . --max-warnings 0",
        "openapi:sync": "node ./scripts/openapi-sync.mjs",
        "openapi:gen": "npx openapi-typescript ./openapi/openapi.snapshot.json -o ./lib/openapi/generated.ts",
        "openapi:update": "yarn openapi:sync && yarn openapi:gen",
        "verify:read-layer": "node ./scripts/verify-read-layer.mjs",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:stress": "playwright test stress-navigation --project=chromium",
        "test:e2e:stress:4": "STRESS_RUN_ID=1 yarn test:e2e:stress:run && STRESS_RUN_ID=2 yarn test:e2e:stress:run && STRESS_RUN_ID=3 yarn test:e2e:stress:run && STRESS_RUN_ID=4 yarn test:e2e:stress:run",
        "test:e2e:stress:run": "playwright test stress-navigation --project=chromium",
        "test:e2e:user-like": "playwright test user-like-recovery --project=chromium"
    },
    "dependencies": {
        "@sentry/nextjs": "10.42.0",
        "@tanstack/react-query": "^5.62.15",
        "@types/js-cookie": "^3.0.6",
        "@vis.gl/react-google-maps": "1.7.1",
        "date-fns": "^3.6.0",
        "eslint": "^9.14.0",
        "fast-deep-equal": "3.1.3",
        "js-cookie": "^3.0.5",
        "lucide-react": "0.525.0",
        "next": "15.5.18",
        "quickjobs-api-wrapper": "git+https://bitbucket.org/quickjobs/api-js.git#c37a4f9e404e53e33dc976ebf7b623165f42b58f",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-hook-form": "^7.54.2",
        "styled-jsx": "5.1.1",
        "ui": "workspace:*"
    },
    "devDependencies": {
        "@netlify/plugin-nextjs": "^5.11.6",
        "@next/eslint-plugin-next": "^15.3.4",
        "@playwright/test": "^1.49.0",
        "@repo/eslint-config": "*",
        "@repo/typescript-config": "*",
        "@types/eslint": "^9.6.1",
        "@types/node": "^22.9.0",
        "@types/react": "^18.3.1",
        "@types/react-dom": "^18.3.1",
        "autoprefixer": "^10.4.20",
        "postcss": "^8.4.47",
        "tailwindcss": "^3.4.14",
        "typescript": "^5.6.3"
    }
}
