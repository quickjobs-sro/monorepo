## API Client Patterns

### API Client Setup
```typescript
// lib/api.ts
const API_BASE = process.env.NEXT_PUBLIC_API_URL || "/api";

async function apiRequest<T>(
  endpoint: string,
  options?: RequestInit
): Promise<T> {
  const res = await fetch(`${API_BASE}${endpoint}`, {
    ...options,
    headers: {
      "Content-Type": "application/json",
      ...options?.headers,
    },
  });

  if (!res.ok) {
    const error = await res.json().catch(() => ({ message: "Request failed" }));
    throw new Error(error.message || `HTTP ${res.status}`);
  }

  return res.json();
}

export const api = {
  get: <T>(endpoint: string) => apiRequest<T>(endpoint, { method: "GET" }),
  post: <T>(endpoint: string, data: unknown) =>
    apiRequest<T>(endpoint, {
      method: "POST",
      body: JSON.stringify(data),
    }),
  put: <T>(endpoint: string, data: unknown) =>
    apiRequest<T>(endpoint, {
      method: "PUT",
      body: JSON.stringify(data),
    }),
  delete: <T>(endpoint: string) =>
    apiRequest<T>(endpoint, { method: "DELETE" }),
};
```

### Usage
```typescript
// In Server Component
const jobs = await api.get<Job[]>("/jobs");

// In Client Component
const handleCreate = async (data: JobFormData) => {
  const job = await api.post<Job>("/jobs", data);
  return job;
};
```

## Common Patterns

### Form Handling
```typescript
"use client";

import { useState } from "react";
import { Button } from "@ui/components/core/button";
import { Input } from "@ui/components/core/input";
import { useToast } from "@ui/hooks/use-toast";

interface JobFormData {
  title: string;
  description: string;
}

export const JobForm = () => {
  const [formData, setFormData] = useState<JobFormData>({
    title: "",
    description: "",
  });
  const [loading, setLoading] = useState(false);
  const [errors, setErrors] = useState<Partial<Record<keyof JobFormData, string>>>({});
  const { toast } = useToast();

  const validate = (): boolean => {
    const newErrors: Partial<Record<keyof JobFormData, string>> = {};
    
    if (!formData.title.trim()) {
      newErrors.title = "Název je povinný";
    }
    
    if (!formData.description.trim()) {
      newErrors.description = "Popis je povinný";
    }
    
    setErrors(newErrors);
    return Object.keys(newErrors).length === 0;
  };

  const handleSubmit = async (e: React.FormEvent<HTMLFormElement>) => {
    e.preventDefault();
    
    if (!validate()) return;
    
    setLoading(true);
    
    try {
      const res = await fetch("/api/jobs", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(formData),
      });
      
      if (!res.ok) throw new Error("Chyba při ukládání");
      
      toast({
        title: "Úspěch",
        description: "Nabídka byla úspěšně vytvořena",
      });
      
      // Reset form or redirect
      setFormData({ title: "", description: "" });
    } catch (error) {
      toast({
        title: "Chyba",
        description: error instanceof Error ? error.message : "Nepodařilo se uložit nabídku",
        variant: "destructive",
      });
    } finally {
      setLoading(false);
    }
  };

  const handleChange = (field: keyof JobFormData) => (
    e: React.ChangeEvent<HTMLInputElement | HTMLTextAreaElement>
  ) => {
    setFormData((prev) => ({ ...prev, [field]: e.target.value }));
    // Clear error when user starts typing
    if (errors[field]) {
      setErrors((prev) => ({ ...prev, [field]: undefined }));
    }
  };

  return (
    <form onSubmit={handleSubmit} className="flex flex-col gap-4">
      <div>
        <Input
          value={formData.title}
          onChange={handleChange("title")}
          placeholder="Název pozice"
          aria-invalid={!!errors.title}
        />
        {errors.title && (
          <p className="text-sm text-destructive mt-1">{errors.title}</p>
        )}
      </div>
      
      <div>
        <textarea
          value={formData.description}
          onChange={handleChange("description")}
          placeholder="Popis pozice"
          className="w-full min-h-[100px] p-2 border rounded"
          aria-invalid={!!errors.description}
        />
        {errors.description && (
          <p className="text-sm text-destructive mt-1">{errors.description}</p>
        )}
      </div>
      
      <Button type="submit" disabled={loading}>
        {loading ? "Ukládám..." : "Uložit"}
      </Button>
    </form>
  );
};
```

### Data Fetching Patterns

#### Server Component Fetching
```typescript
// app/jobs/page.tsx
async function getJobs(): Promise<Job[]> {
  const res = await fetch("https://api.example.com/jobs", {
    next: { 
      revalidate: 3600, // Cache for 1 hour (ISR)
      tags: ["jobs"], // For on-demand revalidation
    },
    headers: {
      "Content-Type": "application/json",
    },
  });
  
  if (!res.ok) {
    throw new Error("Nepodařilo se načíst nabídky");
  }
  
  return res.json();
}

export default async function JobsPage() {
  const jobs = await getJobs();
  
  return <JobList jobs={jobs} />;
}
```

## Utilities & Helpers

### Common Utilities
```typescript
// lib/utils.ts
import { type ClassValue, clsx } from "clsx";
import { twMerge } from "tailwind-merge";

export function cn(...inputs: ClassValue[]) {
  return twMerge(clsx(inputs));
}

// Date formatting
export function formatDate(date: Date | string): string {
  return new Intl.DateTimeFormat("cs-CZ", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(new Date(date));
}

// Type guards
export function isError(error: unknown): error is Error {
  return error instanceof Error;
}
```

### Validation Helpers
```typescript
// lib/validation.ts
export function validateEmail(email: string): boolean {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
}

export function validateRequired(value: string | null | undefined): boolean {
  return value !== null && value !== undefined && value.trim() !== "";
}
```

## Quick Reference

### File Structure
- `page.tsx` - Route page
- `layout.tsx` - Layout wrapper
- `loading.tsx` - Loading UI
- `error.tsx` - Error boundary
- `not-found.tsx` - 404 page
- `route.ts` - API handler

### Component Checklist
- [ ] Server Component by default
- [ ] TypeScript types defined
- [ ] Error handling implemented
- [ ] Loading states included
- [ ] Czech UI text, English code
- [ ] Tailwind utilities used
- [ ] Accessibility considered
- [ ] Responsive design

### Import Order
1. React/Next.js
2. Third-party
3. Local components
4. Local utilities
5. Types (`import type`)

### Common Commands
```bash
# Development
pnpm dev                    # Start dev server
pnpm build                 # Build for production
pnpm lint                  # Run linter
pnpm type-check            # TypeScript check

# Turbo commands
turbo build                # Build all packages
turbo lint                 # Lint all packages
```

#### Client-Side Fetching
```typescript
"use client";

import { useEffect, useState } from "react";
import { useToast } from "@ui/hooks/use-toast";

export const JobsList = () => {
  const [jobs, setJobs] = useState<Job[]>([]);
  const [loading, setLoading] = useState(true);
  const { toast } = useToast();

  useEffect(() => {
    async function fetchJobs() {
      try {
        const res = await fetch("/api/jobs");
        if (!res.ok) throw new Error("Chyba při načítání");
        const data = await res.json();
        setJobs(data);
      } catch (error) {
        toast({
          title: "Chyba",
          description: "Nepodařilo se načíst nabídky",
          variant: "destructive",
        });
      } finally {
        setLoading(false);
      }
    }
    
    fetchJobs();
  }, []);

  if (loading) return <LoadingIndicator />;
  return <JobList items={jobs} />;
};
```

#### Caching Strategies
- **Static**: `cache: 'force-cache'` (default) - cached indefinitely
- **Dynamic**: `cache: 'no-store'` - always fetch fresh
- **ISR**: `next: { revalidate: 3600 }` - revalidate after time
- **On-demand**: `revalidateTag('jobs')` or `revalidatePath('/jobs')`