{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "passThroughEnv": ["SENTRY_AUTH_TOKEN", "API_REVISION", "API_URL", "NEXT_PUBLIC_API_REVISION", "NEXT_PUBLIC_API_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "passThroughEnv": [
        "ADMIN_OAUTH_CLIENT_KEY",
        "ADMIN_OAUTH_CLIENT_SECRET",
        "API_REVISION",
        "API_URL",
        "NEXT_PUBLIC_API_REVISION",
        "NEXT_PUBLIC_API_URL"
      ],
      "persistent": true
    }
  }
}
